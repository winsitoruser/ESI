# Humanify staging environment
# Copy to .env.staging (never commit secrets)

NODE_ENV=production
NEXTAUTH_URL=https://staging.humanify.id
PORT=3021

# Point at a dedicated staging Postgres (not production)
DATABASE_URL=postgresql://humanify:CHANGE_ME@127.0.0.1:5432/humanify_staging

# Auth — use different secrets from production
NEXTAUTH_SECRET=change-me-staging-secret

# SMTP (SumoPod) — may reuse prod relay for QA
SMTP_HOST=smtp.sumopod.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@humanify.id
SMTP_FROM_NAME=Humanify Staging

# Midtrans sandbox
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=

# Redis (optional — multi-instance rate-limit + login-guard)
REDIS_URL=
HUMANIFY_SSO_HANDOFF_TTL_SEC=90

# Observability (opsional)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0
# Uptime monitor: GET /api/health?deep=1

# Redis (optional — rate-limit + login-guard multi-instance)
REDIS_URL=
HUMANIFY_SSO_HANDOFF_TTL_SEC=90
