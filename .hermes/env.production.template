# =============================================================================
# BEDAGANG ERP - PRODUCTION ENVIRONMENT TEMPLATE
# =============================================================================
# Location on server: /var/www/bedagang/.env
# 
# HOW TO USE:
# 1. Copy this file: cp .hermes/env.production.template .env
# 2. Replace ALL placeholders starting with YOUR_
# 3. Generate secrets using: openssl rand -base64 32
# 4. Set file permissions: chmod 600 .env
# =============================================================================

# =============================================================================
# [1] DATABASE CONFIGURATION (REQUIRED)
# =============================================================================
# PostgreSQL - Both DATABASE_URL (Prisma) and individual vars (Sequelize) needed
# Connection Pool: max 20 connections, SSL required for production

# Prisma (primary for reads, introspection)
DATABASE_URL=postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_DB_HOST:5432/YOUR_DB_NAME

# Sequelize (primary for writes, migrations, models)
DB_HOST=YOUR_DB_HOST
DB_PORT=5432
DB_NAME=YOUR_DB_NAME
DB_USER=YOUR_DB_USER
DB_PASSWORD=YOUR_DB_PASSWORD
DB_SSL=true

# Connection Pool Settings
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# Legacy PostgreSQL vars (from .env.example - may not be used)
POSTGRES_HOST=YOUR_DB_HOST
POSTGRES_PORT=5432
POSTGRES_DB=YOUR_DB_NAME
POSTGRES_USER=YOUR_DB_USER
POSTGRES_PASSWORD=YOUR_DB_PASSWORD

# =============================================================================
# [2] AUTHENTICATION & SECRETS (CRITICAL - MUST GENERATE NEW!)
# =============================================================================
# Generate each secret with: openssl rand -base64 32
# THESE ARE NOT OPTIONAL IN PRODUCTION!

# NextAuth (main authentication)
NEXTAUTH_URL=https://YOUR_DOMAIN.com
NEXTAUTH_SECRET=YOUR_GENERATED_SECRET_1

# Fallback auth secret (used in middleware.ts)
AUTH_SECRET=YOUR_GENERATED_SECRET_2

# Session & JWT secrets
SESSION_SECRET=YOUR_GENERATED_SECRET_3
JWT_SECRET=YOUR_GENERATED_SECRET_4
JWT_REFRESH_SECRET=YOUR_GENERATED_SECRET_5
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Encryption key for sensitive data (must be 32 chars)
ENCRYPTION_KEY=YOUR_32_CHAR_ENCRYPTION_KEY

# =============================================================================
# [3] APPLICATION CONFIGURATION (REQUIRED)
# =============================================================================
NODE_ENV=production
PORT=3001

# Public URLs - change to your actual domain
APP_URL=https://YOUR_DOMAIN.com
STORE_APP_URL=https://store.YOUR_DOMAIN.com
BACKEND_URL=https://api.YOUR_DOMAIN.com
NEXT_PUBLIC_API_URL=https://YOUR_DOMAIN.com/api

# =============================================================================
# [4] CORS & SECURITY (REQUIRED)
# =============================================================================
# Comma-separated list of allowed origins for CORS
CORS_ORIGIN=https://YOUR_DOMAIN.com,https://app.YOUR_DOMAIN.com
CORS_ALLOWED_ORIGINS=https://YOUR_DOMAIN.com,https://app.YOUR_DOMAIN.com
ALLOWED_ORIGINS=https://YOUR_DOMAIN.com,https://app.YOUR_DOMAIN.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# [5] MULTI-TENANT CONFIGURATION (REQUIRED)
# =============================================================================
TENANT_ISOLATION_ENABLED=true
TENANT_SUPERADMIN_EMAIL=superadmin@YOUR_DOMAIN.com
TENANT_DEFAULT_ID=00000000-0000-0000-0000-000000000000

# =============================================================================
# [6] PRISMA CONFIGURATION (REQUIRED)
# =============================================================================
# IMPORTANT: Prisma is READ-ONLY in this project
# All writes MUST go through Sequelize
PRISMA_SCHEMA_SYNC_ENABLED=true
PRISMA_ONLY_READ=true
PRISMA_LOG_QUERIES=false

# =============================================================================
# [7] PAYMENT GATEWAYS (OPTIONAL - enable as needed)
# =============================================================================

# Midtrans (Indonesian payment gateway)
MIDTRANS_SERVER_KEY=YOUR_MIDTRANS_SERVER_KEY
MIDTRANS_CLIENT_KEY=YOUR_MIDTRANS_CLIENT_KEY
MIDTRANS_IS_PRODUCTION=true

# Stripe
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET

# Xendit
XENDIT_SECRET_KEY=YOUR_XENDIT_SECRET_KEY
XENDIT_WEBHOOK_TOKEN=YOUR_XENDIT_WEBHOOK_TOKEN
XENDIT_PUBLIC_KEY=YOUR_XENDIT_PUBLIC_KEY

# =============================================================================
# [8] EMAIL SMTP (REQUIRED for transactional emails)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@YOUR_DOMAIN.com
SMTP_PASS=YOUR_SMTP_APP_PASSWORD
SMTP_PASSWORD=YOUR_SMTP_APP_PASSWORD
SMTP_FROM=noreply@YOUR_DOMAIN.com
SMTP_SECURE=false

# =============================================================================
# [9] REDIS CACHING (OPTIONAL - for performance)
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD_IF_ANY
REDIS_DB=0

# =============================================================================
# [10] CLOUD STORAGE (OPTIONAL - for file uploads)
# =============================================================================

# AWS S3
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY
AWS_REGION=ap-southeast-1
AWS_BUCKET_NAME=YOUR_BUCKET_NAME

# Cloudinary
CLOUDINARY_CLOUD_NAME=YOUR_CLOUD_NAME
CLOUDINARY_API_KEY=YOUR_CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=YOUR_CLOUDINARY_API_SECRET

# =============================================================================
# [11] AI PROVIDERS (OPTIONAL - for AI workflow engine)
# =============================================================================
OPENAI_API_KEY=YOUR_OPENAI_KEY_IF_USED
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY_IF_USED
GOOGLE_AI_API_KEY=YOUR_GOOGLE_AI_KEY_IF_USED
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_KEY_IF_USED
GROQ_API_KEY=YOUR_GROQ_KEY_IF_USED

# Ollama (local AI - optional)
OLLAMA_BASE_URL=http://localhost:11434

# =============================================================================
# [12] FEATURE FLAGS (OPTIONAL - adjust as needed)
# =============================================================================
ENABLE_LOYALTY_PROGRAM=true
ENABLE_MULTI_BRANCH=true
ENABLE_ONLINE_ORDERING=false
ENABLE_DELIVERY_TRACKING=false
ENABLE_OFFLINE_MODE=true
ENABLE_MULTI_TENANT=true

# =============================================================================
# [13] BUSINESS DEFAULTS (OPTIONAL)
# =============================================================================
DEFAULT_CURRENCY=IDR
DEFAULT_TIMEZONE=Asia/Jakarta
DEFAULT_LANGUAGE=id

# =============================================================================
# [14] LOGGING (OPTIONAL)
# =============================================================================
LOG_LEVEL=info
LOG_DIR=./logs
LOG_FILE_PATH=./logs/app.log

# =============================================================================
# [15] SUPABASE (OPTIONAL - currently unused but in config)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# =============================================================================
# SECURITY CHECKLIST BEFORE DEPLOYMENT
# =============================================================================
# 1. [ ] All YOUR_* placeholders replaced with actual values
# 2. [ ] All secrets generated fresh with: openssl rand -base64 32
# 3. [ ] NEXTAUTH_URL uses HTTPS and correct domain
# 4. [ ] DATABASE_URL has correct credentials and SSL enabled
# 5. [ ] CORS_ORIGIN includes all your frontend domains
# 6. [ ] File permissions set: chmod 600 .env
# 7. [ ] .env added to .gitignore (never commit secrets!)
# 8. [ ] Hardcoded URLs fixed (see .hermes/ENV_AUDIT_FINDINGS.md)
# =============================================================================
