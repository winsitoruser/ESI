  status             String?        @default("completed") @db.VarChar(20)
  subject            String?        @db.VarChar(300)
  body               String?
  call_duration      Int?
  call_recording_url String?        @db.VarChar(500)
  email_from         String?        @db.VarChar(200)
  email_to           Json?          @default("[]")
  email_cc           Json?          @default("[]")
  email_opened       Boolean?       @default(false)
  email_clicked      Boolean?       @default(false)
  meeting_location   String?        @db.VarChar(300)
