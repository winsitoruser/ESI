generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model Customers {
  id                  String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String                      @db.VarChar(255)
  email               String?                     @db.VarChar(255)
  phone               String?                     @db.VarChar(50)
  address             String?
  createdAt           DateTime?                   @default(now()) @db.Timestamp(6)
  updatedAt           DateTime?                   @default(now()) @db.Timestamp(6)
  customerType        enum_Customers_customerType @default(individual)
  companyName         String?                     @db.VarChar(255)
  picName             String?                     @db.VarChar(255)
  picPosition         String?                     @db.VarChar(100)
  contact1            String?                     @db.VarChar(50)
  contact2            String?                     @db.VarChar(50)
  companyEmail        String?                     @db.VarChar(255)
  companyAddress      String?
  taxId               String?                     @db.VarChar(50)
  customer_loyalty    customer_loyalty?
  finance_receivables finance_receivables[]

  @@index([companyName], map: "idx_customers_company_name")
  @@index([customerType], map: "idx_customers_customer_type")
}

model SequelizeMeta {
  name String @id @db.VarChar(255)
}

model activation_requests {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  partner_id         String?   @db.Uuid
  package_id         String?   @db.Uuid
  business_documents Json?
  notes              String?
  status             String?   @default("pending") @db.VarChar(50)
  reviewed_by        String?   @db.Uuid
  reviewed_at        DateTime? @db.Timestamp(6)
  review_notes       String?
  created_at         DateTime? @default(now()) @db.Timestamp(6)
  updated_at         DateTime? @default(now()) @db.Timestamp(6)
  partners           partners? @relation(fields: [partner_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([partner_id], map: "idx_activation_requests_partner")
  @@index([status], map: "idx_activation_requests_status")
}

model ai_executions {
  id                String        @id @db.Uuid
  tenant_id         String?       @db.Uuid
  workflow_id       String?       @db.Uuid
  ai_model_id       String?       @db.Uuid
  triggered_by      Int?
  trigger_type      String?       @db.VarChar(30)
  status            String?       @default("pending") @db.VarChar(20)
  input_data        Json?
  output_data       Json?
  error_message     String?
  input_tokens      Int?          @default(0)
  output_tokens     Int?          @default(0)
  total_cost        Decimal?      @default(0) @db.Decimal(10, 6)
  execution_time_ms Int?          @default(0)
  entity_type       String?       @db.VarChar(50)
  entity_id         String?       @db.VarChar(255)
  metadata          Json?         @default("\"{}\"")
  started_at        DateTime?     @db.Timestamptz(6)
  completed_at      DateTime?     @db.Timestamptz(6)
  created_at        DateTime?     @default(now()) @db.Timestamptz(6)
  ai_models         ai_models?    @relation(fields: [ai_model_id], references: [id], onUpdate: NoAction)
  tenants           tenants?      @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  ai_workflows      ai_workflows? @relation(fields: [workflow_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([created_at], map: "idx_ai_executions_created")
  @@index([status], map: "idx_ai_executions_status")
  @@index([tenant_id], map: "idx_ai_executions_tenant")
  @@index([workflow_id], map: "idx_ai_executions_workflow")
}

model ai_models {
  id                 String          @id @db.Uuid
  tenant_id          String?         @db.Uuid
  code               String          @db.VarChar(50)
  name               String          @db.VarChar(100)
  provider           String          @db.VarChar(50)
  model_id           String          @db.VarChar(100)
  description        String?
  capabilities       Json?           @default("\"[]\"")
  config             Json?           @default("\"{}\"")
  api_key_ref        String?         @db.VarChar(200)
  is_default         Boolean?        @default(false)
  is_active          Boolean?        @default(true)
  cost_per_1k_input  Decimal?        @default(0) @db.Decimal(10, 6)
  cost_per_1k_output Decimal?        @default(0) @db.Decimal(10, 6)
  max_context_tokens Int?            @default(128000)
  metadata           Json?           @default("\"{}\"")
  created_by         Int?
  created_at         DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at         DateTime?       @default(now()) @db.Timestamptz(6)
  ai_executions      ai_executions[]
  tenants            tenants?        @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  ai_workflows       ai_workflows[]

  @@index([provider], map: "idx_ai_models_provider")
  @@index([tenant_id], map: "idx_ai_models_tenant")
}

model ai_workflows {
  id                    String          @id @db.Uuid
  tenant_id             String?         @db.Uuid
  code                  String          @db.VarChar(50)
  name                  String          @db.VarChar(150)
  description           String?
  category              String?         @default("general") @db.VarChar(50)
  module                String?         @default("crm") @db.VarChar(20)
  ai_model_id           String?         @db.Uuid
  system_prompt         String?
  user_prompt_template  String?
  input_schema          Json?           @default("\"{}\"")
  output_schema         Json?           @default("\"{}\"")
  tools                 Json?           @default("\"[]\"")
  trigger_type          String?         @default("manual") @db.VarChar(30)
  trigger_config        Json?           @default("\"{}\"")
  is_active             Boolean?        @default(true)
  sort_order            Int?            @default(0)
  execution_count       Int?            @default(0)
  avg_execution_time_ms Int?            @default(0)
  metadata              Json?           @default("\"{}\"")
  created_by            Int?
  created_at            DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at            DateTime?       @default(now()) @db.Timestamptz(6)
  ai_executions         ai_executions[]
  ai_models             ai_models?      @relation(fields: [ai_model_id], references: [id], onUpdate: NoAction)
  tenants               tenants?        @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([category], map: "idx_ai_workflows_category")
  @@index([module], map: "idx_ai_workflows_module")
  @@index([tenant_id], map: "idx_ai_workflows_tenant")
}

model billing_cycles {
  id                   String                     @id @db.Uuid
  subscription_id      String                     @db.Uuid
  period_start         DateTime                   @db.Timestamptz(6)
  period_end           DateTime                   @db.Timestamptz(6)
  base_amount          Decimal                    @default(0) @db.Decimal(10, 2)
  overage_amount       Decimal                    @default(0) @db.Decimal(10, 2)
  discount_amount      Decimal                    @default(0) @db.Decimal(10, 2)
  tax_amount           Decimal                    @default(0) @db.Decimal(10, 2)
  total_amount         Decimal                    @default(0) @db.Decimal(10, 2)
  currency             String                     @default("IDR") @db.VarChar(3)
  status               enum_billing_cycles_status @default(pending)
  processed_at         DateTime?                  @db.Timestamptz(6)
  due_date             DateTime                   @db.Timestamptz(6)
  metadata             Json?
  created_at           DateTime                   @db.Timestamptz(6)
  updated_at           DateTime                   @db.Timestamptz(6)
  subscriptions        subscriptions              @relation(fields: [subscription_id], references: [id], onDelete: Cascade)
  invoices             invoices[]
  payment_transactions payment_transactions[]

  @@index([due_date], map: "billing_cycles_due_date")
  @@index([period_start, period_end], map: "billing_cycles_period_start_period_end")
  @@index([status], map: "billing_cycles_status")
  @@index([subscription_id], map: "billing_cycles_subscription_id")
}

model branches {
  id              String                     @id @db.Uuid
  store_id        String?                    @db.Uuid
  code            String                     @unique(map: "branches_code_idx") @db.VarChar(50)
  name            String                     @db.VarChar(255)
  type            enum_branches_type?        @default(branch)
  address         String?
  city            String?                    @db.VarChar(255)
  province        String?                    @db.VarChar(255)
  postal_code     String?                    @db.VarChar(10)
  phone           String?                    @db.VarChar(20)
  email           String?                    @db.VarChar(255)
  manager_id      Int?
  operating_hours Json?                      @default("[]") @db.Json
  is_active       Boolean?                   @default(true)
  settings        Json?                      @default("{}") @db.Json
  created_at      DateTime                   @db.Timestamptz(6)
  updated_at      DateTime                   @db.Timestamptz(6)
  tenant_id       String?                    @db.Uuid
  region          String?                    @db.VarChar(100)
  last_sync_at    DateTime?                  @db.Timestamptz(6)
  sync_status     enum_branches_sync_status? @default(never)
  users           users?                     @relation(fields: [manager_id], references: [id])
  tenants         tenants?                   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  employee_kpis   employee_kpis[]
  employees       employees[]
  sync_logs       sync_logs[]

  @@index([is_active])
  @@index([manager_id])
  @@index([region])
  @@index([store_id])
  @@index([tenant_id])
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model business_packages {
  id               String             @id @db.Uuid
  code             String             @unique @db.VarChar(100)
  name             String             @db.VarChar(255)
  description      String?
  industry_type    String?            @db.VarChar(50)
  business_type_id String?            @db.Uuid
  category         String?            @default("starter") @db.VarChar(50)
  icon             String?            @db.VarChar(100)
  color            String?            @default("#3B82F6") @db.VarChar(20)
  pricing_tier     String?            @default("basic") @db.VarChar(50)
  base_price       Decimal?           @default(0) @db.Decimal(10, 2)
  is_active        Boolean?           @default(true)
  is_featured      Boolean?           @default(false)
  sort_order       Int?               @default(0)
  metadata         Json?              @default("{}") @db.Json
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  updated_at       DateTime           @default(now()) @db.Timestamptz(6)
  business_types   business_types?    @relation(fields: [business_type_id], references: [id])
  package_features package_features[]
  package_modules  package_modules[]
  tenant_packages  tenant_packages[]

  @@index([business_type_id], map: "business_packages_business_type_id")
  @@index([industry_type], map: "business_packages_industry_type")
  @@index([is_active], map: "business_packages_is_active")
}

model business_type_modules {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_type_id String         @db.Uuid
  module_id        String         @db.Uuid
  is_default       Boolean?       @default(true)
  is_optional      Boolean?       @default(false)
  created_at       DateTime?      @default(now()) @db.Timestamp(6)
  business_types   business_types @relation(fields: [business_type_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  modules          modules        @relation(fields: [module_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([business_type_id, module_id])
}

model business_types {
  id                       String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                     String                     @unique @db.VarChar(50)
  name                     String                     @db.VarChar(100)
  description              String?
  icon                     String?                    @db.VarChar(50)
  is_active                Boolean?                   @default(true)
  created_at               DateTime?                  @default(now()) @db.Timestamp(6)
  updated_at               DateTime?                  @default(now()) @db.Timestamp(6)
  business_packages        business_packages[]
  business_type_modules    business_type_modules[]
  dashboard_configurations dashboard_configurations[]
  tenants                  tenants[]
}

model crm_automation_logs {
  id                   String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rule_id              String?               @db.Uuid
  trigger_event        String?               @db.VarChar(50)
  entity_type          String?               @db.VarChar(30)
  entity_id            String?               @db.Uuid
  status               String?               @db.VarChar(20)
  actions_executed     Json?                 @default("[]")
  error_message        String?
  execution_time_ms    Int?
  created_at           DateTime?             @default(now()) @db.Timestamptz(6)
  crm_automation_rules crm_automation_rules? @relation(fields: [rule_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([rule_id], map: "crm_automation_logs_rule_id")
}

model crm_automation_rules {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id           String?               @db.Uuid
  name                String                @db.VarChar(200)
  description         String?
  rule_type           String?               @db.VarChar(30)
  trigger_event       String?               @db.VarChar(50)
  trigger_entity      String?               @db.VarChar(30)
  trigger_conditions  Json?                 @default("[]")
  actions             Json?                 @default("[]")
  schedule_cron       String?               @db.VarChar(50)
  is_active           Boolean?              @default(true)
  execution_count     Int?                  @default(0)
  last_executed_at    DateTime?             @db.Timestamptz(6)
  error_count         Int?                  @default(0)
  priority            Int?                  @default(0)
  stop_on_match       Boolean?              @default(false)
  created_by          Int?
  created_at          DateTime?             @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?             @default(now()) @db.Timestamptz(6)
  crm_automation_logs crm_automation_logs[]

  @@index([tenant_id], map: "crm_automation_rules_tenant_id")
}

model crm_calendar_events {
