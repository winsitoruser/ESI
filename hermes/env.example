# SumoPod AI — untuk Hermes Agent (ESI ERP)
# Dapatkan API key di: https://ai.sumopod.com → AI → API Keys
#
# Salin ke ~/.hermes/.env (jangan commit):
#   cp hermes/env.example ~/.hermes/.env
#   # edit SUMOPOD_AI_API_KEY

SUMOPOD_AI_API_KEY=sk-your-key-here
SUMOPOD_AI_BASE_URL=https://ai.sumopod.com/v1

# Hermes juga menerima alias OpenAI-compatible:
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_BASE_URL=https://ai.sumopod.com/v1
